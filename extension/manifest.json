{
  "manifest_version": 3,
  "name": "YT-Presence",
  "version": "2.0",
  "description": "Syncs YouTube/YouTube Music playback status to Discord Rich Presence via a local daemon.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*",
        "*://*.amazon.co.jp/gp/video/*",
        "*://*.amazon.co.jp/v/*",
        "*://*.amazon.co.jp/d/*",
        "*://*.amazon.com/gp/video/*",
        "*://*.amazon.com/v/*",
        "*://*.amazon.com/d/*",
        "*://*.primevideo.com/*"
      ],
      "js": [
        "content_loader.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*",
        "*://*.amazon.co.jp/gp/video/*",
        "*://*.amazon.co.jp/v/*",
        "*://*.amazon.co.jp/d/*",
        "*://*.amazon.com/gp/video/*",
        "*://*.amazon.com/v/*",
        "*://*.amazon.com/d/*",
        "*://*.primevideo.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
